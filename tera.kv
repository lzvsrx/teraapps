WindowManager:
    LoginScreen:
    RegisterScreen:
    DashboardScreen:

<LoginScreen>:
    name: 'login'
    username: username
    password: password
    canvas.before:
        # Fundo Preto Profundo
        Color:
            rgba: 0.02, 0.024, 0.04, 1 # #05060A
        Rectangle:
            pos: self.pos
            size: self.size
        
        # Efeito de Glow/Gradiente Superior (Roxo)
        Color:
            rgba: 0.66, 0.33, 0.97, 0.15
        Ellipse:
            pos: self.width * 0.5 - 200, self.height - 200
            size: 400, 400
        
        # Efeito de Glow Inferior (Azul)
        Color:
            rgba: 0.23, 0.51, 0.96, 0.1
        Ellipse:
            pos: -100, -100
            size: 300, 300

    BoxLayout:
        orientation: 'vertical'
        padding: [40, 60, 40, 40]
        spacing: 30

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.4
            spacing: 10
            
            Image:
                source: 'assets/logo.png'
                allow_stretch: True
                keep_ratio: True
            
            Label:
                text: "TERA"
                font_name: 'Orbitron'
                font_size: 48
                color: 1, 1, 1, 1
                bold: True
                outline_width: 1
                outline_color: 0.66, 0.33, 0.97, 0.5

        BoxLayout:
            orientation: 'vertical'
            spacing: 15
            size_hint_y: None
            height: 130

            TextInput:
                id: username
                hint_text: "IDENTIFICAÇÃO DO AGENTE"
                font_name: 'Exo2'
                multiline: False
                background_normal: ''
                background_color: 0.04, 0.06, 0.12, 1
                foreground_color: 1, 1, 1, 1
                padding: [20, 15]
                cursor_color: 0.22, 0.83, 0.93, 1

            TextInput:
                id: password
                hint_text: "CHAVE DE ACESSO"
                font_name: 'Exo2'
                password: True
                multiline: False
                background_normal: ''
                background_color: 0.04, 0.06, 0.12, 1
                foreground_color: 1, 1, 1, 1
                padding: [20, 15]
                cursor_color: 0.66, 0.33, 0.97, 1

        Button:
            text: "INICIALIZAR SISTEMA"
            font_name: 'Orbitron'
            size_hint_y: None
            height: 60
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            on_release: root.do_login()
            canvas.before:
                Color:
                    rgba: 0.66, 0.33, 0.97, 1
                Line:
                    width: 2
                    rectangle: self.x, self.y, self.width, self.height
                Color:
                    rgba: 0.66, 0.33, 0.97, 0.1
                Rectangle:
                    pos: self.pos
                    size: self.size

        Button:
            text: "CADASTRAR NOVO AGENTE"
            font_name: 'Exo2'
            size_hint_y: None
            height: 30
            background_color: 0, 0, 0, 0
            color: 0.22, 0.83, 0.93, 1
            on_release: app.root.current = 'register'

<RegisterScreen>:
    name: 'register'
    username: username
    password: password
    profession: profession
    canvas.before:
        Color:
            rgba: 0.02, 0.024, 0.04, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [40, 40, 40, 40]
        spacing: 20

        Label:
            text: "RECRUTAMENTO TERA"
            font_name: 'Orbitron'
            font_size: 24
            color: 0.66, 0.33, 0.97, 1
            size_hint_y: None
            height: 80

        TextInput:
            id: username
            hint_text: "NOME DE USUÁRIO"
            font_name: 'Exo2'
            size_hint_y: None
            height: 55
            background_normal: ''
            background_color: 0.04, 0.06, 0.12, 1
            foreground_color: 1, 1, 1, 1
            padding: [15, 15]

        TextInput:
            id: password
            hint_text: "SENHA DE SEGURANÇA"
            font_name: 'Exo2'
            password: True
            size_hint_y: None
            height: 55
            background_normal: ''
            background_color: 0.04, 0.06, 0.12, 1
            foreground_color: 1, 1, 1, 1
            padding: [15, 15]

        TextInput:
            id: profession
            hint_text: "ÁREA DE ATUAÇÃO"
            font_name: 'Exo2'
            size_hint_y: None
            height: 55
            background_normal: ''
            background_color: 0.04, 0.06, 0.12, 1
            foreground_color: 1, 1, 1, 1
            padding: [15, 15]

        Widget:
            size_hint_y: 0.1

        Button:
            text: "CONFIRMAR REGISTRO"
            font_name: 'Orbitron'
            size_hint_y: None
            height: 60
            background_normal: ''
            background_color: 0.66, 0.33, 0.97, 1
            color: 1, 1, 1, 1
            bold: True
            on_release: root.do_register()

        Button:
            text: "VOLTAR"
            font_name: 'Exo2'
            size_hint_y: None
            height: 30
            background_color: 0, 0, 0, 0
            color: 0.23, 0.51, 0.96, 1
            on_release: app.root.current = 'login'

<DashboardScreen>:
    name: 'dashboard'
    canvas.before:
        Color:
            rgba: 0.02, 0.024, 0.04, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: 0
        spacing: 0

        # Header Metálico
        BoxLayout:
            size_hint_y: None
            height: 80
            padding: [20, 10]
            spacing: 15
            canvas.before:
                Color:
                    rgba: 0.07, 0.1, 0.18, 1 # Azul escuro metálico
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.23, 0.51, 0.96, 0.5 # Linha de brilho azul
                Line:
                    points: [self.x, self.y, self.x + self.width, self.y]
                    width: 1.5

            Image:
                source: 'assets/logo.png'
                size_hint_x: None
                width: 50
            
            Label:
                text: "TERA COMMAND"
                font_name: 'Orbitron'
                color: 1, 1, 1, 1
                bold: True
                font_size: 22
                halign: 'left'
                text_size: self.size

        # Área de Status
        BoxLayout:
            orientation: 'vertical'
            padding: 30
            spacing: 25

            Label:
                text: root.user_info
                font_name: 'Exo2'
                halign: 'center'
                valign: 'middle'
                font_size: 20
                color: 0.22, 0.83, 0.93, 1
                text_size: self.width, None
                line_height: 1.3

            # Grid de Ferramentas
            ScrollView:
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [10, 20]
                    spacing: 20

                    Button:
                        text: "GERAR RELATÓRIO DO SETOR"
                        font_name: 'Orbitron'
                        size_hint_y: None
                        height: 55
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        color: 1, 1, 1, 1
                        on_release: root.save_report()
                        canvas.before:
                            Color:
                                rgba: 0.23, 0.51, 0.96, 1
                            Line:
                                width: 1.5
                                rectangle: self.x, self.y, self.width, self.height
                            Color:
                                rgba: 0.23, 0.51, 0.96, 0.1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                    
                    Button:
                        text: "SINCRONIZAR ARQUIVOS"
                        font_name: 'Orbitron'
                        size_hint_y: None
                        height: 55
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        color: 1, 1, 1, 1
                        canvas.before:
                            Color:
                                rgba: 0.66, 0.33, 0.97, 1
                            Line:
                                width: 1.5
                                rectangle: self.x, self.y, self.width, self.height
                            Color:
                                rgba: 0.66, 0.33, 0.97, 0.1
                            Rectangle:
                                pos: self.pos
                                size: self.size

        # Footer de Desconexão
        Button:
            text: "ENCERRAR SESSÃO SEGURA"
            font_name: 'Orbitron'
            size_hint_y: None
            height: 60
            background_normal: ''
            background_color: 0.8, 0.1, 0.1, 0.2
            color: 1, 0.4, 0.4, 1
            on_release: app.root.current = 'login'
            canvas.before:
                Color:
                    rgba: 0.8, 0.1, 0.1, 0.5
                Line:
                    points: [self.x, self.y + self.height, self.x + self.width, self.y + self.height]
                    width: 1
